<DefaultWindow xmlns="https://spacestation14.io"
            xmlns:tabs="clr-namespace:Content.Client.Options.UI.Tabs"
            xmlns:imperial="clr-namespace:Content.Client.Imperial.Options"
            Title="{Loc 'ui-options-title'}"
            MinSize="920 450">  <!-- Imperial Options (OLD: MinSize="800 450) -->
    <TabContainer Name="Tabs" Access="Public">
        <tabs:MiscTab Name="MiscTab" />
        <tabs:GraphicsTab Name="GraphicsTab" />
        <tabs:KeyRebindTab Name="KeyRebindTab" />
        <tabs:AudioTab Name="AudioTab" />
        <tabs:AccessibilityTab Name="AccessibilityTab" />
        <tabs:AdminOptionsTab Name="AdminOptionsTab" />
        <!-- Imperial Options -->
        <imperial:ImperialOptionsMenuTab Name="ImperialTab" />
        <!-- Imperial Options -->
    </TabContainer>
</DefaultWindow>
