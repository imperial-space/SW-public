<DefaultWindow xmlns="https://spacestation14.io"
    Title="{Loc 'helm-ui-title'}"
    MinSize="720 225"
    SetSize="720 225">

    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True" Margin="8">

        <BoxContainer Orientation="Vertical" HorizontalExpand="True" HorizontalAlignment="Center">

            <LayoutContainer Name="SliderArea" HorizontalAlignment="Center" Margin="0 40 0 0">

                <TextureRect Name="HelmBackground"
                             Stretch="KeepAspectCentered"
                             TexturePath="/Textures/Imperial/Medieval/Ships/SteeringWheel.rsi/helm_background.png"
                             TextureScale="20 2"/>

                <TextureRect Name="HelmIndecator"
                             Stretch="KeepAspectCentered"
                             TexturePath="/Textures/Imperial/Medieval/Ships/SteeringWheel.rsi/wheel_indecator.png"
                             TextureScale="4 4"/>

            </LayoutContainer>
        </BoxContainer>

        <PanelContainer StyleClasses="BackgroundPanel" VerticalExpand="True">
            </PanelContainer>

    </BoxContainer>
</DefaultWindow>
