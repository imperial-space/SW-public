<Control
    xmlns="https://spacestation14.io"
    Margin="5"
    HorizontalExpand="True"
    VerticalExpand="True">
    <PanelContainer Name="Wrapper" StyleClasses="PdaBorderRect">
        <BoxContainer Orientation="Vertical">
            <BoxContainer
                HorizontalExpand="True"
                Orientation="Vertical"
                SizeFlagsStretchRatio="1">
                <BoxContainer HorizontalExpand="True" Orientation="Horizontal">
                    <TextureRect
                        Name="Icon"
                        Margin="4"
                        TextureScale="2 2"/>
                    <BoxContainer HorizontalExpand="True" Margin="4" VerticalExpand="True" Orientation="Vertical">
                        <Label
                            Name="Name"
                            MinWidth="50"
                            Margin="0 4"
                            HorizontalExpand="True" />
                        <Label
                            Name="LevelLabel"
                            MinWidth="50"
                            Margin="0 4"
                            Text="{Loc 'imperial-hm-ui-level'}"
                            HorizontalExpand="True" />
                    </BoxContainer>
                    <BoxContainer HorizontalExpand="True" Margin="4" VerticalExpand="True" Orientation="Vertical">
                        <TextureButton Name="Info" Scale="0.5 0.5"
                                       VerticalAlignment="Top"
                                       SetSize="32 32"
                                       Margin="4 0"
                                       TexturePath="/Textures/Interface/VerbIcons/information.svg.192dpi.png"
                                       MouseFilter="Stop"/>
                    </BoxContainer>
                </BoxContainer>
                <BoxContainer Margin="4" Orientation="Horizontal">
                    <Button
                        Name="IncreaseButton"
                        Access="Public"
                        Margin="2"
                        HorizontalExpand="True"
                        Text="+" />
                    <Button
                        Name="DecreaseButton"
                        Margin="2"
                        HorizontalExpand="True"
                        Text="-" />
                </BoxContainer>
            </BoxContainer>
            <BoxContainer
                Name="VisualizerContainer"
                HorizontalExpand="True"
                Orientation="Vertical"
                SizeFlagsStretchRatio="5"
                VerticalExpand="True" />
        </BoxContainer>
    </PanelContainer>
</Control>
