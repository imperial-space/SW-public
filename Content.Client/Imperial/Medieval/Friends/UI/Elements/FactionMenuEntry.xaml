<Control
    xmlns="https://spacestation14.io"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:friends="clr-namespace:Content.Client.Imperial.Medieval.Friends.UI.Elements"
    xmlns:imp="clr-namespace:Content.Client.Imperial.Roadmap.UI"
    HorizontalExpand="True"
    MinHeight="50"
    SetHeight="50"
    Margin="4 4">
    <imp:BorderedPanelContainer ModulateSelfOverride="White"
                    BackgroundPanelColor="#25252A"
                    HorizontalExpand="True"
                    VerticalExpand="True"
                    VerticalAlignment="Center"
                    BorderRadius="40">
        <BoxContainer Name="Main"
                      Orientation="Horizontal"
                      HorizontalExpand="True"
                      VerticalExpand="True"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      Margin="5 10">
            <BoxContainer Orientation="Horizontal"
                          Margin="4 0"
                          HorizontalExpand="True"
                          SizeFlagsStretchRatio="3">
                <RichTextLabel Name="NameLabel"
                               Text="Тест тестович"
                               HorizontalAlignment="Left"/>
            </BoxContainer>
            <BoxContainer Name="GroupInfo"
                          Margin="4 0"
                          HorizontalExpand="True"
                          VerticalExpand="True"
                          VerticalAlignment="Center"
                          SizeFlagsStretchRatio="4">
                <BoxContainer Orientation="Horizontal"
                              HorizontalExpand="True"
                              VerticalExpand="True"
                              VerticalAlignment="Center">
                    <friends:ColoredOptionButton Name="GroupSelector"
                                                 HorizontalExpand="True"
                                                 StyleClasses="ButtonSquare"
                                                 OptionStyleClasses="ButtonSquare"
                                                 ModulateSelfOverride="#00000000"
                                                 VerticalExpand="True"
                                                 Margin="0"
                                                 HideTriangle="True"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center">
                        <BoxContainer VerticalExpand="True"
                                HorizontalExpand="True">
                            <PanelContainer VerticalExpand="True"
                                    HorizontalExpand="True"
                                    Margin="-7.5 -4">
                                <PanelContainer.PanelOverride>
                                    <gfx:StyleBoxFlat BackgroundColor="#1f1f24"/>
                                </PanelContainer.PanelOverride>
                                <RichTextLabel
                                    Text="Назначить группу"
                                    HorizontalExpand="True"
                                    VerticalExpand="True"
                                    Margin="0 0"
                                    HorizontalAlignment="Center"/>
                            </PanelContainer>
                        </BoxContainer>
                    </friends:ColoredOptionButton>
                    <Button Name="GroupRemoveButton"
                            HorizontalExpand="True"
                            StyleClasses="ButtonSquare"
                            Margin="-1"
                            Visible="False">
                        <BoxContainer Orientation="Horizontal">
                            <TextureRect TextureScale="0.5 0.5"
                                         Margin="1"
                                         Stretch="KeepAspectCentered"
                                         TexturePath="/Textures/Interface/Nano/cross.svg.png"
                                         HorizontalAlignment="Left"/>
                            <RichTextLabel Name="GroupRemoveButtonText"
                                           Text=""
                                           HorizontalExpand="True"
                                           VerticalExpand="True"
                                           Margin="4 0"
                                           HorizontalAlignment="Right"/>
                        </BoxContainer>
                    </Button>
                    <PanelContainer VerticalExpand="True"
                                    Margin="10 0">
                        <PanelContainer.PanelOverride>
                            <gfx:StyleBoxFlat BackgroundColor="#474747"/>
                        </PanelContainer.PanelOverride>
                        <RichTextLabel Name="Objective"
                                       Text="Test test"
                                       HorizontalExpand="True"
                                       VerticalExpand="True"
                                       Margin="4 4"
                                       Visible="True"/>
                    </PanelContainer>
                </BoxContainer>
            </BoxContainer>
        </BoxContainer>
        <BoxContainer Margin="4 0"
                      HorizontalAlignment="Right">
            <Button Name="RemoveButton"
                    ModulateSelfOverride="#00000000">
                <RichTextLabel Text="Уволить"
                               HorizontalAlignment="Left"/>
            </Button>
        </BoxContainer>
    </imp:BorderedPanelContainer>
</Control>
