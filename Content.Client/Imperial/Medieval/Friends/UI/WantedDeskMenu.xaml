<DefaultWindow
    xmlns="https://spacestation14.io"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
    xmlns:imp="clr-namespace:Content.Client.Imperial.Roadmap.UI"
    Title="{Loc 'wanted-desk-title'}"
    MinSize="1024 512"
    SetSize="1024 512">
    <BoxContainer Name="Main"
                  Orientation="Vertical"
                  HorizontalExpand="True"
                  VerticalExpand="True">
        <ScrollContainer HScrollEnabled="False"
                         VerticalExpand="True"
                         HorizontalExpand="True"
                         Margin="2">
            <GridContainer Name="Wanted"
                           Columns="3"
                           VerticalExpand="True"
                           HorizontalExpand="True">
                <!-- Rest of this populated in .cs -->
            </GridContainer>
        </ScrollContainer>
    </BoxContainer>
</DefaultWindow>
