<DefaultWindow xmlns="https://spacestation14.io"
            Title="Предупреждение"
            MinSize="500 150"
            SetSize="500 350">
    <BoxContainer Orientation="Vertical"
                  HorizontalExpand="True">
        <ScrollContainer HorizontalExpand="True"
                      VerticalExpand="True"
                      HScrollEnabled="False"
                      SizeFlagsStretchRatio="4">
            <BoxContainer Orientation="Vertical">
                <RichTextLabel Name="TopBanner" VerticalExpand="True" SizeFlagsStretchRatio="1" Margin="4"/>
            </BoxContainer>
        </ScrollContainer>
        <CheckBox Name="Checkbox" Text="Я прочитал текст и буду соответствовать роли" VerticalExpand="True" SizeFlagsStretchRatio="1" Margin="4"/>
        <Button Name="RequestButton"
                Text="{Loc 'ghost-roles-window-request-role-button'}"
                Disabled="True"
                TextAlign="Center"
                HorizontalAlignment="Center"
                VerticalExpand="True"
                SizeFlagsStretchRatio="1"
                Margin="4"/>
    </BoxContainer>
</DefaultWindow>
