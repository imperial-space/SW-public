<Control xmlns="https://spacestation14.io"
         xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
         xmlns:ui="clr-namespace:Content.Client.Imperial.UI">
    <PanelContainer HorizontalExpand="True" VerticalExpand="True" Margin="0 0 0 4">
        <PanelContainer.PanelOverride>
            <graphics:StyleBoxFlat BackgroundColor="#1a1a1a"/>
        </PanelContainer.PanelOverride>

        <BoxContainer Orientation="Horizontal" HorizontalExpand="False" Margin="8">
            <CheckBox Name="Checkbox" HorizontalExpand="False" />
            <!-- <ui:ImperialCheckbox Name="Checkbox" HorizontalExpand="False" /> -->
            <Label Name="Label" HorizontalAlignment="Left" HorizontalExpand="False" />
        </BoxContainer>
    </PanelContainer>
</Control>
