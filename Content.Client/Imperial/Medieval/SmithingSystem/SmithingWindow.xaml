<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc 'cp14-smith-ui-title'}"
                      MinSize="520 480">

    <BoxContainer Orientation="Vertical">
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
            <Label Name="StepsLabel" Align="Left" HorizontalExpand="True" Margin="5 0 0 0" />
            <Label Name="PointsLabel" Align="Right" HorizontalExpand="True" Margin="0 0 5 0" />
        </BoxContainer>

        <LayoutContainer Margin="5" Name="MainLayout" HorizontalExpand="True" VerticalExpand="True">
            <TextureRect Name="ItemSpriteView"
                         Stretch="KeepAspectCentered"
                         MouseFilter="Ignore" />
        </LayoutContainer>

        <Button Name="StartGameButton" Text="{Loc 'imperial-hm-ui-start'}" HorizontalExpand="True" SetHeight="30" />
    </BoxContainer>
</controls:FancyWindow>
