<DefaultWindow
    xmlns="https://spacestation14.io"
    Title="{Loc easel-window-confirmaion-title}" MinSize="340 320" SetSize="340 320"
    xmlns:paintings="clr-namespace:Content.Client.Imperial.Medieval.PlayerCreations.Paintings">
    <BoxContainer VerticalExpand="True" Orientation="Vertical">
        <RichTextLabel HorizontalAlignment="Center"  VerticalExpand="True" Text="{Loc easel-window-confirmation-warning}"/>
        <TextEdit HorizontalExpand="True" Editable="True" VerticalExpand="True" Name="PaintingNameField"/>
        <TextEdit HorizontalExpand="True" Editable="True" VerticalExpand="True" Name="PaintingAuthorField"/>
        <Button Name="SendButton" Text="{Loc easel-window-confirmation-send-button}"/>
    </BoxContainer>
</DefaultWindow>
