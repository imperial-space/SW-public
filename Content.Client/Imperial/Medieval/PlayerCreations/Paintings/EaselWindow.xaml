<DefaultWindow
    xmlns="https://spacestation14.io"
    Title="{Loc easel-window-title}" MinSize="400 440"
    xmlns:paintings="clr-namespace:Content.Client.Imperial.Medieval.PlayerCreations.Paintings">
    <BoxContainer Orientation="Vertical">
        <paintings:CanvasDrawControl Name="CanvasControl" MinWidth="200" VerticalExpand="True" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <ColorSelectorSliders Name="CanvasColor"/>
        <Button Name="Send" HorizontalExpand="True" Text="{Loc 'imperial-hm-ui-send'}"/>
    </BoxContainer>
</DefaultWindow>
