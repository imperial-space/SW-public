<DefaultWindow
    xmlns="https://spacestation14.io"
    Title="{Loc creations-dialog-title}" MinSize="160 100">
    <BoxContainer Orientation="Vertical">
        <Label Name="Subtitle" Text="{Loc creations-dialog-subtitle}"></Label>
        <BoxContainer Orientation="Horizontal">
            <Button VerticalExpand="False" HorizontalAlignment="Center" Name="CancelButton" Text="{Loc creations-dialog-cancel}"></Button>
            <Button VerticalExpand="False" HorizontalAlignment="Center" Name="ConfirmButton" StyleClasses="Caution" Text="{Loc creations-dialog-confirm}"></Button>
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
