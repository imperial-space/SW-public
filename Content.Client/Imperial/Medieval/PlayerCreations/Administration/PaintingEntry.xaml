<Control xmlns="https://spacestation14.io"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:ui="clr-namespace:Content.Client.Options.UI">
  <PanelContainer HorizontalAlignment="Stretch" StyleClasses="WindowHeadingBackground" Margin="5">
    <BoxContainer HorizontalAlignment="Stretch" Orientation="Vertical">
      <TextureRect Name="PaintingView" Margin="0 15 0 0" SetSize="190 190" Stretch="KeepAspectCentered"/>
      <RichTextLabel Name="PaintingName" HorizontalAlignment="Center" Text="{Loc 'imperial-hm-ui-testpainting'}"/>
      <RichTextLabel Name="PaintingAuthor" HorizontalAlignment="Center" Text="{Loc 'imperial-hm-ui-urist'}"/>
      <Button Name="MoreButton" HorizontalExpand="True" Text="{Loc 'imperial-hm-ui-moree'}"/>
      <BoxContainer Orientation="Horizontal" HorizontalExpand="True" HorizontalAlignment="Stretch">
        <Button Name="AcceptButton" HorizontalExpand="True" Text="{Loc 'imperial-hm-ui-accept'}"/>
        <Button Name="DeclineButton" HorizontalExpand="True" Text="{Loc 'imperial-hm-ui-decline'}"/>
      </BoxContainer>
    </BoxContainer>
  </PanelContainer>
</Control>
