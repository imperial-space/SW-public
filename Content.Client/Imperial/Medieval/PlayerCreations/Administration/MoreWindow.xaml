<DefaultWindow
  xmlns="https://spacestation14.io"
  Title="{Loc more-window-title}" MinSize="350 400"
  xmlns:paintings="clr-namespace:Content.Client.Imperial.Medieval.PlayerCreations.Paintings">
    <BoxContainer Orientation="Vertical">
        <ScrollContainer HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalExpand="True" VerticalExpand="True" HScrollEnabled="False">
            <PanelContainer VerticalExpand="True" HorizontalExpand="True" SetWidth="330" MinWidth="330">
                <BoxContainer Name="BoxContent" Orientation="Vertical" VerticalAlignment="Stretch">
                    <GridContainer Name="Contents" Columns="2" VerticalExpand="True" HorizontalAlignment="Center"/>
                </BoxContainer>
            </PanelContainer>
        </ScrollContainer>
    </BoxContainer>
</DefaultWindow>
