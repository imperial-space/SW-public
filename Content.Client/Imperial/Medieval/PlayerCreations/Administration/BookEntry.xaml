<Control xmlns="https://spacestation14.io"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:ui="clr-namespace:Content.Client.Options.UI">
  <PanelContainer HorizontalAlignment="Stretch" StyleClasses="WindowHeadingBackground" Margin="5">
    <BoxContainer HorizontalAlignment="Stretch" Orientation="Vertical">
      <RichTextLabel Name="BookName" HorizontalAlignment="Center" Text="Книга 123"/>
      <RichTextLabel Name="BookAuthor" HorizontalAlignment="Center" Text="Урист МакЧеловек (Ligyb)"/>
      <Button Name="ReadButton" HorizontalExpand="True" Text="Читать"/>
      <Button Name="MoreButton" HorizontalExpand="True" Text="Подробнее"/>
      <BoxContainer Orientation="Horizontal" HorizontalExpand="True" HorizontalAlignment="Stretch">
        <Button Name="AcceptButton" HorizontalExpand="True" Text="Принять"/>
        <Button Name="DeclineButton" HorizontalExpand="True" Text="Отклонить"/>
      </BoxContainer>
    </BoxContainer>
  </PanelContainer>
</Control>
