<DefaultWindow
  xmlns="https://spacestation14.io"
  Title="{Loc 'nrp-panel-title'}" MinSize="600 500">
    <BoxContainer Orientation="Vertical">
        <ScrollContainer VerticalExpand="True" HScrollEnabled="False">
            <BoxContainer Name="MessagesContainer" Access="Public" HorizontalAlignment="Stretch" Orientation="Vertical">
            </BoxContainer>
        </ScrollContainer>
        <BoxContainer Orientation="Horizontal" Margin="7" MinHeight="30" MaxHeight="30">
            <Button Name="AdminStatsButton" Text="{Loc 'nrp-panel-button-stats'}"/>
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
