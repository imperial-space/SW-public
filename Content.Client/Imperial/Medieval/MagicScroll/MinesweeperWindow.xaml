<!-- ===================================================================== -->
<!-- MinesweeperWindow.xaml -->
<!-- ===================================================================== -->
<!-- Purpose: XAML layout for minesweeper rune decryption game -->
<!-- Author: rhailrake -->
<!-- ===================================================================== -->

<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:customControls="clr-namespace:Content.Client.Administration.UI.CustomControls"
               Title="{Loc 'imperial-hm-magicscroll-sdecrypt'}"
               MinSize="500 400">
    <BoxContainer Orientation="Vertical" Margin="10">
        <Label Name="RuneLabel" Text="{Loc 'imperial-hm-magicscroll-rdecypt'}" HorizontalAlignment="Center" Margin="0 0 0 10"/>

        <customControls:HSeparator Margin="0 10"/>

        <BoxContainer Orientation="Vertical">
            <Label Name="StatusLabel" Text="{Loc 'imperial-hm-magicscroll-guide1'}" HorizontalAlignment="Center"/>
            <Label Name="InfoLabel" Text="{Loc 'imperial-hm-magicscroll-guide2'}" HorizontalAlignment="Center" Margin="0 5"/>
        </BoxContainer>

        <BoxContainer Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 10">
            <Label Name="MinesLabel" Text="{Loc 'imperial-hm-magicscroll-mines'}" />
            <Label Name="OpenedLabel" Text="{Loc 'imperial-hm-magicscroll-open'}" Margin="10 0 0 0"/>
            <CheckBox Name="FlagModeCheckbox" Text="{Loc 'imperial-hm-magicscroll-mode'}" Margin="10 0 0 0"/>
            <Button Name="HintButton" Text="{Loc 'imperial-hm-magicscroll-tip'}" Margin="10 0 0 0"/>
        </BoxContainer>

        <GridContainer Name="MinesweeperGrid" Columns="5" HSeparationOverride="2" VSeparationOverride="2" Margin="0 10">
        </GridContainer>

        <BoxContainer Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 10">
            <Button Name="CloseButto" Text="{Loc 'imperial-hm-magicscroll-close'}" Margin="10 0 0 0"/>
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
