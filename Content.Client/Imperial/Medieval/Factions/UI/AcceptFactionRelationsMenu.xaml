<DefaultWindow
    xmlns="https://spacestation14.io"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
    xmlns:imp="clr-namespace:Content.Client.Imperial.Roadmap.UI"
    xmlns:friends="clr-namespace:Content.Client.Imperial.Medieval.Friends.UI.Elements"
    Title="{Loc 'medieval-hm-relations-change'}"
    MinSize="512 180"
    SetSize="512 185">
    <BoxContainer Name="Main"
                  Orientation="Vertical"
                  HorizontalExpand="True"
                  VerticalExpand="True">
        <RichTextLabel Name="MainLabel" Margin="4"/>
        <BoxContainer Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalExpand="True" Margin="4">
            <Button Name="SendButton" Text="{Loc 'medieval-hm-relations-accept'}" Margin="8 4" HorizontalAlignment="Center"/>
            <Button Name="DiscardButton" Text="{Loc 'medieval-hm-relations-decline'}" Margin="8 4" HorizontalAlignment="Center"/>
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
