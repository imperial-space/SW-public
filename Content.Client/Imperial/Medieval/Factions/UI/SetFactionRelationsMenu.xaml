<DefaultWindow
    xmlns="https://spacestation14.io"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
    xmlns:imp="clr-namespace:Content.Client.Imperial.Roadmap.UI"
    xmlns:friends="clr-namespace:Content.Client.Imperial.Medieval.Friends.UI.Elements"
    Title="{Loc 'medieval-hm-relations-suggest'}"
    MinSize="512 240"
    SetSize="512 248">
    <BoxContainer Name="Main"
                  Orientation="Vertical"
                  HorizontalExpand="True"
                  VerticalExpand="True">
        <OptionButton Name="FactionSelectButton" Margin="4" HorizontalAlignment="Left"/>
        <OptionButton Name="RelationSelectButton" Margin="4" HorizontalAlignment="Left"/>
        <RichTextLabel Name="MainLabel" Margin="4"/>
        <RichTextLabel Name="PaperWarning" Text="{Loc 'medieval-hm-relations-ucant'}" Visible="False" Margin="4"/>
        <BoxContainer Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalExpand="True" Margin="4">
            <Button Name="SendButton" Text="{Loc 'medieval-hm-relations-suggesst'}" Margin="8 4" HorizontalAlignment="Center"/>
            <Button Name="DiscardButton" Text="{Loc 'medieval-hm-relations-cancel'}" Margin="8 4" HorizontalAlignment="Center"/>
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
