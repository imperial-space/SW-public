<imp:BorderedPanelContainer
    xmlns="https://spacestation14.io"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:imp="clr-namespace:Content.Client.Imperial.Roadmap.UI"
    ModulateSelfOverride="White"
    BorderRadius="15"
    BackgroundPanelColor="#16161a"
    Margin="0 10">
    <BoxContainer Name="Box"
                  Margin="4"
                  VerticalExpand="True"
                  Orientation="Vertical"
                  Access="Public">
        <BoxContainer Name="GroupBox"
                      Orientation="Horizontal"
                      VerticalAlignment="Top"
                      SetHeight="50">
            <imp:BorderedPanelContainer Name="GroupNamePanel"
                            HorizontalAlignment="Left"
                            Margin="5 5"
                            VerticalExpand="True"
                            ModulateSelfOverride="White"
                            BorderRadius="25"
                            BackgroundPanelColor="#1f1f24">
                <RichTextLabel Name="GroupNameText"
                               Text="Без группы"
                               HorizontalExpand="True"
                               Margin="15 0"
                               VerticalExpand="True"
                               HorizontalAlignment="Center"/>
            </imp:BorderedPanelContainer>
            <imp:BorderedPanelContainer Name="ObjectivePanel"
                            HorizontalAlignment="Left"
                            Margin="5 10"
                            VerticalExpand="True"
                            ModulateSelfOverride="White"
                            BorderRadius="25"
                            BackgroundPanelColor="#474747">
                <RichTextLabel Name="Objective"
                               Text=""
                               HorizontalExpand="True"
                               VerticalExpand="True"
                               Margin="15 0"
                               HorizontalAlignment="Center"/>
            </imp:BorderedPanelContainer>
            <PanelContainer Name="ObjectiveEditPanel" Margin="15 10" HorizontalExpand="True" Visible="False">
                <LineEdit Name="ObjectiveEdit" HorizontalExpand="True" VerticalExpand="True" >
                </LineEdit>
                <RichTextLabel Name="ObjectiveEditTip" Margin="5 5" HorizontalAlignment="Left" VerticalAlignment="Center" Text="[color=#46464df2]Не более 32 символов.[/color]" />
            </PanelContainer>
            <Button Name="SetObjectiveButton"
                    ModulateSelfOverride="#00000000"
                    Margin="10"
                    VerticalExpand="True">
                <RichTextLabel Name="SetObjectiveButtonText"
                               Text="Назначить задачу"
                               VerticalExpand="True"/>
            </Button>
            <RichTextLabel Name="AliveCounter"
                           Text=""
                           Margin="5"
                           HorizontalAlignment="Right"
                           VerticalExpand="True"
                           HorizontalExpand="True"/>
        </BoxContainer>
    </BoxContainer>
</imp:BorderedPanelContainer>
