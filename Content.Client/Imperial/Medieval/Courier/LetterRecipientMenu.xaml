<DefaultWindow
    xmlns="https://spacestation14.io"
    Title="{Loc 'courier-letter-recipient-window-title'}"
    MinSize="320 512"
    SetSize="320 512">
    <BoxContainer Name="Main"
                  Orientation="Vertical"
                  HorizontalExpand="True"
                  VerticalExpand="True">
        <ScrollContainer HScrollEnabled="False"
                         VerticalExpand="True"
                         HorizontalExpand="True"
                         Margin="0">
            <GridContainer Name="Recipients"
                           Columns="1"
                           VerticalExpand="True"
                           HorizontalExpand="True">
                <!-- Content is filled in code -->
            </GridContainer>
        </ScrollContainer>
    </BoxContainer>
</DefaultWindow>
