<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               Title="Настройка Путевого Камня"
               MinSize="250 180"
               SetSize="250 180"
               x:Class="Content.Client.Imperial.Medieval.Waystones.UI.WaystoneAdminMenu">

    <BoxContainer Orientation="Vertical" Margin="10">

        <BoxContainer Orientation="Horizontal" Margin="0 0 0 10">
            <Label Text="Цена отправления:" Margin="0 0 10 0" />
            <LineEdit Name="PriceInInput" HorizontalExpand="True" />
        </BoxContainer>

        <BoxContainer Orientation="Horizontal" Margin="0 0 0 10">
            <Label Text="Цена приема:" Margin="0 0 10 0" />
            <LineEdit Name="PriceOutInput" HorizontalExpand="True" />
        </BoxContainer>

        <Button Name="ApplyButton" Text="Применить тарифы" HorizontalAlignment="Center" />

    </BoxContainer>
</DefaultWindow>
