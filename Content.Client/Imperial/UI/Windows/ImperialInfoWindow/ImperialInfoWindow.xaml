<iui:ImperialInfoWindow
    xmlns="https://spacestation14.io"
    xmlns:i="clr-namespace:Content.Client.Imperial.UI"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    xmlns:iui="clr-namespace:Content.Client.Imperial.UI.Windows.ImperialInfoWindow"
    HeaderText="Imperial"
    MinSize="600 0"
    SetSize="600 190"
    Resizable="False">
    <BoxContainer Name="Contents" Access="Public" Orientation="Vertical" VerticalAlignment="Center" Margin="20 20 20 10">
        <Label Align="Center" Name="HeaderLabelText" Text="{Loc 'imperial-ui-info-text'}" StyleClasses="LabelSubTextPass1" Access="Public" HorizontalAlignment="Center" />
        <controls:HSpacer Spacing="5"/>

        <RichTextLabel Name="InfoText" StyleClasses="LabelSubTextPassMediumBuy" Access="Public" HorizontalAlignment="Center" />
        <controls:HSpacer Spacing="20"/>

        <BoxContainer VerticalAlignment="Center" HorizontalAlignment="Center">
            <i:BaseImperialButton Name="SubmitButton" HorizontalAlignment="Stretch" HorizontalExpand="True" StyleClasses="PassButtonMedium">
               <Label Name="SubmitButtonText" Text="{Loc 'imperial-ui-confirm-button-text' }" HorizontalAlignment="Center" Access="Public" />
            </i:BaseImperialButton>
        </BoxContainer>
    </BoxContainer>
</iui:ImperialInfoWindow>
