<iui:RedirectWindow
    xmlns="https://spacestation14.io"
    xmlns:i="clr-namespace:Content.Client.Imperial.UI"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    xmlns:iui="clr-namespace:Content.Client.Imperial.UI.Windows.RedirectWindow"
    HeaderText="Imperial"
    MinSize="500 0"
    SetSize="500 260"
    Resizable="False">
    <BoxContainer Name="Contents" Access="Public" Orientation="Vertical" VerticalAlignment="Center" Margin="20">
        <Label Name="HeaderLabelText" Text="{Loc 'imperial-pass-ui-redirect-header'}" StyleClasses="LabelSubTextPass1" Access="Public" />
        <controls:HSpacer Spacing="5"/>
        <RichTextLabel Name="InfoText" StyleClasses="LabelSubTextPassMediumBuy" Access="Public" />
        <controls:HSpacer Spacing="20"/>
        <i:ImperialLineEdit Name="RedirectLink" Editable="False" Access="Public" />
        <controls:HSpacer Spacing="20"/>

        <BoxContainer Name="ButtonsContainer" Access="Public" HorizontalAlignment="Stretch" Orientation="Horizontal" HorizontalExpand="True" MinSize="0 30" >
            <i:BaseImperialButton Name="RedirectButton" HorizontalAlignment="Stretch" HorizontalExpand="True" StyleClasses="PassButtonMedium">
                <Label Name="RedirectButtonText" Text="{Loc 'imperial-pass-ui-redirect-accept' }" HorizontalAlignment="Center" Access="Public" />
            </i:BaseImperialButton>

            <i:BaseImperialButton
                Name="CancelButton"
                MinWidth="50"
                StyleClasses="PassButtonMedium"
                NormalColor="#676767"
                HoverColor="#808080"
                PressedColor="#676767"
                Access="Public"
                Text="imperial-pass-ui-redirect-cancel">
            </i:BaseImperialButton>
        </BoxContainer>
    </BoxContainer>
</iui:RedirectWindow>
