### Компонент тайника. Используется в горшках, подушках кресел и т.д.

comp-secret-stash-action-hide-success = Вы спрятали { THE($item) } в {$stashname}.
comp-secret-stash-action-hide-container-not-empty = Здесь уже что-то есть?!
comp-secret-stash-action-hide-item-too-big = { CAPITALIZE(THE($item)) } слишком большой для {$stashname}.
comp-secret-stash-action-get-item-found-something = В {$stashname} что-то было!
comp-secret-stash-on-examine-found-hidden-item = В {$stashname} что-то спрятано!
comp-secret-stash-on-destroyed-popup = Что-то выпало из {$stashname}!

### Глаголы
comp-secret-stash-verb-insert-into-stash = Спрятать предмет
comp-secret-stash-verb-insert-message-item-already-inside = В {$stashname} уже есть предмет.
comp-secret-stash-verb-insert-message-no-item = Спрячьте { THE($item) } в {$stashname}.
comp-secret-stash-verb-take-out-item = Достать предмет
comp-secret-stash-verb-take-out-message-something = Достать содержимое {$stashname}.
comp-secret-stash-verb-take-out-message-nothing = В {$stashname} ничего нет.

comp-secret-stash-verb-close = Закрыть
comp-secret-stash-verb-cant-close = Вы не можете закрыть {$stashname} этим.
comp-secret-stash-verb-open = Открыть

