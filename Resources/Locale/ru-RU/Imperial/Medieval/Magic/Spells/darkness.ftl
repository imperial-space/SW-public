# Mana Burn Field

medieval-mana-burn-field-popup = My strength is leaving me

medieval-spell-speach-mana-burn-field = C̕͏ą͜mpų́͡s͞ ̵̀Ĺa̕͜ngúo̸̕r̵is̨̢͢

medieval-store-spells-darkness-mana-burn-field-beginner-name = Mana depletion field
medieval-store-spells-darkness-mana-burn-field-beginner-desc = Places a field with a 2.5 tile radius that gradually burns the mana of entities standing on it.

medieval-store-spells-darkness-mana-burn-field-middle-name = Mana depletion field
medieval-store-spells-darkness-mana-burn-field-middle-desc = Places a field with a 3 tile radius that gradually burns the mana of entities standing on it.

medieval-store-spells-darkness-mana-burn-field-senior-name = Mana depletion hole
medieval-store-spells-darkness-mana-burn-field-senior-desc = Places a field with a 3.5 tile radius that gradually burns the mana of entities standing on it and pulls them toward the center of the field.