ent-MedievalMyrmexRecycler = переформовщик смолы мирмексов
    .desc = Позволяет изготовить более сложные материалы из смолы.
.suffix = { "Средневековье, мирмексы" }
ent-MedievalMyrmexToxicHole = токсичная яма мирмексов
    .desc = Это яма и она токсичная. В ней можно перерабатывать трупы.
.suffix = { "Средневековье, мирмексы" }
ent-MedievalCurseClot = проклятый сгусток
    .desc = Пузырчатый пульсирующий сгусток. Может понизить стабильность барьера.
.suffix = { "Средневековье, мирмексы" }
ent-MedievalMyrmexIncubator = инкубатор сгустков
    .desc = Вырабатывает проклятые сгустки. Пахнет ужасно.
.suffix = { "Средневековье, мирмексы" }
ent-MedievalMyrmexQueenLayEggAction = Снести яйцо
ent-MedievalMyrmexBigHole = большая смоляная нора мирмексов
    .desc = Эта огромная яма позволяет перемещаться даже самым большим созданиям.
.suffix = { "СПАВНИТЬ В ЛОГОВЕ МИРМЕКСОВ ТОЛЬКО, Средневековье, мирмексы" }
ent-MedievalMyrmexBoostAction = Ускорение
    .desc = Позволяет мирмексу на короткое время значительно увеличить свою скорость.
ent-MedievalMyrmexToggleArmorAction = Преобразование панциря
    .desc = Позволяет мирмексу увеличить прочность своего панциря в замен на скорость.
ent-MedievalMyrmexToggleStunAction = Подготовить удар
    .desc = Позволяет мирмексу подготовиться к нанесению сильного удара, который опрокинет противника.
ent-MedievalMyrmexSpawnAction = Возвести стену
    .desc = Позволяет мирмексу рабочему моментально возвести стену.
ent-MedievalMyrmexToggleStealthAction = Переключить маскировку
    .desc = Позволяет мирмексу слиться с местностью.
ent-MedievalMyrmexHealAction = Восстановление
    .desc = Позволяет мирмексу излечить чужие раны.
ent-MedievalMyrmexBigHoleExit = большая смоляная нора мирмексов
    .desc = Эта огромная яма позволяет перемещаться даже самым большим созданиям.
.suffix = { "НЕ СПАВНИТЬ СЛОМАЕТЕ СЕРВ НАХУЙ, Средневековье, мирмексы" }

