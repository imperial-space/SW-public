ent-BaseSubdermalImplant = имплант
    .desc = Микрочип, который вживляют под кожу.
    .suffix = { "" }
ent-SadTromboneImplant = имплант Грустный тромбон
    .desc = Проигрывает грустную мелодию при смерти владельца.
    .suffix = { "" }
ent-LightImplant = имплант Свет
    .desc = Заставляет вашу кожу излучать слабый свет.
    .suffix = { "" }
ent-TrackingImplant = имплант Трекер
    .desc = Отслеживает владельца через сеть датчиков.
    .suffix = { "" }
ent-StorageImplant = имплант Хранилище
    .desc = Изготовленный с применением bluespace-технологии, позволяет поместить несколько предметов в подкожное скрытое хранилище.
    .suffix = { "" }
ent-FreedomImplant = имплант Свобода
    .desc = Позволяет три раза освободиться от наручников и других ограничителей.
    .suffix = { "" }
ent-MicroBombImplant = имплант Микробомба
    .desc = Миссия провалена, пользователь будет взорван чтобы предотвратить потерю дорогостоящего обмундирования.
    .suffix = { "" }
ent-MacroBombImplant = имплант Макробомба
    .desc = Маленький имплант вызывающий большой взрыв, будьте осторожны, чтобы не стать неприятным сюрпризом для ваших же товарищей.
    .suffix = { "" }
ent-DeathAcidifierImplant = имплант кислотной смерти
    .desc = Этот имплантат расплавляет пользователя и его вещи после смерти.
    .suffix = { "" }
ent-MindShieldImplant = имплант защиты разума
    .desc = { "" }
    .suffix = { "" }
ent-FakeMindShieldImplant = имплант ложной защиты разума
    .desc = Имплант, заставляющий устройства воспринимать вас, как человека с имплантом защиты разума.
    .suffix = { "" }
ent-EmpImplant = имплант ЭМИ
    .desc = Испускает ЭМИ по необходимости.
    .suffix = { "" }
ent-UplinkImplant = имплант Аплинк
    .desc = Одноразовый имплантер, имплантат позволяет пользователю получить доступ аплинку по желанию.
    .suffix = { "" }
ent-BikeHornImplant = имплант велосипедного гудка
    .desc = Этот имплант позволяет пользователю издавать звуки велосипедного гудка по желанию.
    .suffix = { "" }
ent-ScramImplant = имплант побега
    .desc = Имплант, позволяющий дважды телепортироваться на большое расстояние. Выживание не гарантировано.
    .suffix = { "" }
ent-DnaScramblerImplant = имплант смены ДНК
    .desc = Позволяет единоразово полностью сменить ваше ДНК, делая вас абсолютно новым человеком.
    .suffix = { "" }
ent-DeathRattleImplant = имплант предсмертного хрипа
    .desc = Если вы будете близки к смерти, сообщит в рацию о вашем состоянии.
    .suffix = { "" }
ent-RadioImplant = имплант радио
    .desc = Позволяет пользоваться рацией без нужды в гарнитуре.
    .suffix = { "" }
ent-DeathRattleImplantCentcomm = имплант предсмертного хрипа ЦентКомма
    .desc = { ent-BaseImplanter.desc }
    .suffix = { "" }
