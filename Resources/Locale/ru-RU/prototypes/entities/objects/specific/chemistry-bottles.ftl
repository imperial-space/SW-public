    .suffix = { "" }
ent-AntiholChemistryBottle = бутылочка антиголя
    .desc = Вызывает удаление алкогольного опьянения при вводе в организм. При большом количестве реагента выводит токсины из организма.Не имеет передоза.
    .suffix = { "" }
ent-SalbutamolChemistryBottle = бутылочка сальбутамола
    .desc = Лекарство, лечащее гипоксию и кровопотерю. Используйте это как дополнительный реагент в начале смены. Не имеет передоза.
    .suffix = { "" }
