    .desc = A formidable siege weapon, the terror of all fortress walls. Enter coordinates, taking into account that X = 0, Y = 0 - the center of the catapult.
    .suffix = { "Medieval" }
ent-MedievalCatapultAmmoBarrel = small empty barrel
    .desc = Empty catapult ammunition. Can be loaded with gunpowder. Does virtually no damage, good only for intimidation. Average spread, average arrival speed.
    .suffix = { "Medieval, catapult ammunition" }
